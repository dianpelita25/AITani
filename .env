# =======================================================================
# == KONFIGURASI UNTUK DEVELOPMENT LOKAL ==
# =======================================================================
# Baris ini memberitahu aplikasi React Anda untuk berbicara dengan
# server backend (Wrangler) yang berjalan di komputer Anda.
VITE_API_BASE_URL=http://127.0.0.1:8787

# =======================================================================
# == KONFIGURASI LAINNYA (TIDAK PERLU DIUBAH SEKARANG) ==
# =======================================================================
# Variabel di bawah ini tidak digunakan saat ini, jadi kita bisa
# membiarkannya apa adanya.
VITE_SUPABASE_URL=https://dummy.supabase.co
VITE_SUPABASE_ANON_KEY=dummykey.updateyourkkey.here
VITE_OPENAI_API_KEY=your-openai-api-key-here
VITE_GEMINI_API_KEY=your-gemini-api-key-here
VITE_ANTHROPIC_API_KEY=your-anthropic-api-key-here
VITE_GOOGLE_ANALYTICS_ID=your-google-analytics-id-here
VITE_ADSENSE_ID=your-adsense-id-here
VITE_PERPLEXITY_API_KEY=your-perplexity-api-key-here
VITE_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key-here

# =======================================================================
# == KONFIGURASI PRODUCTION (DINONAKTIFKAN SEMENTARA) ==
# =======================================================================
# Tanda '#' di awal baris ini menonaktifkannya.
# Kita akan mengaktifkannya kembali saat kita akan men-deploy.
